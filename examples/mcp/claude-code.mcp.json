{
  "mcpServers": {
    "unreal": {
      "command": "uvx",
      "args": ["unrealmcp"],
      "env": {
        "UNREAL_MCP_HOST": "127.0.0.1",
        "UNREAL_MCP_PORT": "8765"
      }
    },
    "unity": {
      "command": "node",
      "args": ["%USERPROFILE%\\GameCourseAI\\engine-bridges\\unity\\server\\build\\index.js"],
      "env": {
        "UNITY_MCP_HOST": "127.0.0.1",
        "UNITY_MCP_PORT": "8090"
      }
    },
    "godot": {
      "command": "node",
      "args": ["%USERPROFILE%\\GameCourseAI\\engine-bridges\\godot\\server\\dist\\index.js"],
      "env": {
        "GODOT_MCP_HOST": "127.0.0.1",
        "GODOT_MCP_PORT": "9080"
      }
    },
    "blender": {
      "command": "uvx",
      "args": ["blender-mcp"],
      "env": {
        "BLENDER_MCP_HOST": "127.0.0.1",
        "BLENDER_MCP_PORT": "9876"
      }
    }
  }
}
